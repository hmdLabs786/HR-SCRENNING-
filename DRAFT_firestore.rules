rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && request.auth.token.email == "habban.madani786@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidCandidate(data) {
      return data.keys().hasAll(['name', 'email', 'status', 'appliedDate']) &&
             data.keys().size() >= 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.status in ['PENDING', 'SCREENED', 'SHORTLISTED', 'REJECTED', 'INTERVIEW_SCHEDULED'] &&
             data.appliedDate is string && // ISO timestamp
             (!('score' in data) || (data.score is number && data.score >= 0 && data.score <= 100)) &&
             (!('matchReasoning' in data) || (data.matchReasoning is string && data.matchReasoning.size() <= 5000)) &&
             (!('resumeText' in data) || (data.resumeText is string && data.resumeText.size() <= 500000)) &&
             (!('skills' in data) || (data.skills is list && data.skills.size() <= 100))
    }

    function isValidJobConfig(data) {
      return data.keys().hasAll(['title', 'description']) &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 10000
    }

    // --- Collections ---

    match /candidates/{candidateId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      
      allow create: if isVerified() && isValidId(candidateId) && isValidCandidate(incoming());
      
      allow update: if isVerified() && isValidId(candidateId) && (
        isAdmin() || 
        (
          isValidCandidate(incoming()) && (
            // Action: Update Status
            (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'interviewDate'])) ||
            // Action: Full screening update
            (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'score', 'matchReasoning', 'skills']))
          )
        )
      );
      
      allow delete: if isAdmin();
    }

    match /config/{configId} {
      allow get: if isVerified();
      allow write: if isAdmin() && isValidId(configId) && isValidJobConfig(incoming());
    }
  }
}
